# --- Payload / database ---
# Production: a Postgres connection string (Neon/Supabase/your own).
# Local dev: leave empty → falls back to a local SQLite file (zero setup).
DATABASE_URI=
# Long random string (openssl rand -base64 32)
PAYLOAD_SECRET=

# --- Media storage (Vercel Blob) ---
# Optional. If unset, uploads are stored on local disk (fine for dev, not Vercel).
# On Vercel this is injected automatically when a Blob store is connected to the
# project; locally, run `vercel env pull .env.local` to fetch it for testing.
BLOB_READ_WRITE_TOKEN=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://camilosanchez.studio

# --- Seed (optional overrides) ---
SEED_ADMIN_EMAIL=admin@camilosanchez.studio
SEED_ADMIN_PASSWORD=changeme123
